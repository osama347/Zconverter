set(_zconverter_macdeployqt "@MACDEPLOYQT_EXECUTABLE@")
set(_zconverter_app_bundle "$ENV{DESTDIR}${CMAKE_INSTALL_PREFIX}/zconverter.app")

if(EXISTS "${_zconverter_app_bundle}")
    execute_process(
        COMMAND "${_zconverter_macdeployqt}" "${_zconverter_app_bundle}" -always-overwrite -no-codesign
        RESULT_VARIABLE _deploy_result
    )

    if(NOT _deploy_result EQUAL 0)
        message(FATAL_ERROR "macdeployqt failed with exit code ${_deploy_result}")
    endif()
endif()
